# Production environment — copy to Azure App Service Configuration
NEXT_PUBLIC_SITE_URL=https://bavanextechnologies.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NODE_ENV=production
WEBSITES_PORT=8080
WEBSITES_ENABLE_APP_SERVICE_STORAGE=false

# Chatbot email — Zoho Mail SMTP (recommended)
SUPPORT_EMAIL=hello@bavanextechnologies.com
SUPPORT_FROM_EMAIL=support-as@bavanextechnologies.com
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=support-as@bavanextechnologies.com
ZOHO_SMTP_PASSWORD=your_zoho_app_password_here

# Optional fallback (only if not using Zoho SMTP)
# SENDGRID_API_KEY=your_sendgrid_api_key
